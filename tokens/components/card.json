{
  "$description": "Card component tokens - Multiple surface variants",
  "card": {
    "default": {
      "background": {
        "$type": "color",
        "$value": "{brand.white}",
        "$description": "Standard white card"
      },
      "border": {
        "$type": "color",
        "$value": "{neutral.200}"
      },
      "text": {
        "$type": "color",
        "$value": "{neutral.900}"
      },
      "shadow": {
        "$type": "boxShadow",
        "$value": {
          "x": "0px",
          "y": "2px",
          "blur": "8px",
          "spread": "0px",
          "color": "rgba(0, 0, 0, 0.08)"
        }
      }
    },
    "subtle": {
      "background": {
        "$type": "color",
        "$value": "{neutral.50}",
        "$description": "Light gray card for subtle emphasis"
      },
      "border": {
        "$type": "color",
        "$value": "{neutral.200}"
      },
      "text": {
        "$type": "color",
        "$value": "{neutral.900}"
      }
    },
    "elevated": {
      "background": {
        "$type": "color",
        "$value": "{brand.white}"
      },
      "border": {
        "$type": "color",
        "$value": "transparent"
      },
      "text": {
        "$type": "color",
        "$value": "{neutral.900}"
      },
      "shadow": {
        "$type": "boxShadow",
        "$value": {
          "x": "0px",
          "y": "4px",
          "blur": "16px",
          "spread": "0px",
          "color": "rgba(0, 0, 0, 0.12)"
        }
      }
    },
    "expressive": {
      "blue-purple": {
        "background": {
          "$type": "color",
          "$value": "{gradient.blue-purple}",
          "$description": "Gradient card for expressive content"
        },
        "text": {
          "$type": "color",
          "$value": "{brand.white}"
        }
      },
      "ocean": {
        "background": {
          "$type": "color",
          "$value": "{gradient.ocean}"
        },
        "text": {
          "$type": "color",
          "$value": "{brand.white}"
        }
      },
      "sunset": {
        "background": {
          "$type": "color",
          "$value": "{gradient.sunset}"
        },
        "text": {
          "$type": "color",
          "$value": "{brand.white}"
        }
      },
      "slate": {
        "background": {
          "$type": "color",
          "$value": "{gradient.slate}"
        },
        "text": {
          "$type": "color",
          "$value": "{brand.white}"
        }
      }
    },
    "interactive": {
      "hover": {
        "shadow": {
          "$type": "boxShadow",
          "$value": {
            "x": "0px",
            "y": "6px",
            "blur": "20px",
            "spread": "0px",
            "color": "rgba(0, 0, 0, 0.15)"
          }
        }
      },
      "pressed": {
        "shadow": {
          "$type": "boxShadow",
          "$value": {
            "x": "0px",
            "y": "1px",
            "blur": "4px",
            "spread": "0px",
            "color": "rgba(0, 0, 0, 0.1)"
          }
        }
      }
    }
  }
}
